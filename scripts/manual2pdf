#!/bin/bash

set -o pipefail

mydir=$(dirname "$0")
mydir=$(cd "${mydir}" && pwd)
srcdir=$(cd "${mydir}/.." && pwd)

cd "${srcdir}" || exit 1

texstyle=manual.sty

declare -r input_fname="${1:-Manual.asciidoc}"
declare -r xml_fname="${input_fname%.*}.xml"
declare -r tex_fname="${input_fname%.*}.tex"
declare -r pdf_fname="${input_fname%.*}.pdf"
declare -r extension_path="${srcdir}/extensions/feature_blocks.rb"

declare -r create_tex_output='yes'

run_dblatex() {
	# Suppress repetitive image conversion warnings from dblatex; images are still embedded.
	"$@" 2> >(grep -v "^Cannot convert '" >&2)
}

run_pdflatex() {
	# Suppress repetitive PDF-string warnings generated by math-heavy headings.
	"$@" 2>&1 | grep -v "Package hyperref Warning: Token not allowed in a PDF string (Unicode):" \
		| grep -v "^(hyperref)                removing "
	return ${PIPESTATUS[0]}
}

# if we run on macOS with asciidoctor and TeX from Macports
declare -x TEXINPUTS=".:/opt/local/share/dblatex/latex/style:/opt/local/share/dblatex/latex/misc:"

rm -f *.aux *.bbl *.cb* *.lo* *.idx *.toc *.tex *.xml *.glo *.4tc *.dvi *.tmp *.xref

# we have to set the revdate here. Otherwise asciidoctor uses
# the timestamp of the source file.
declare revdate=$(git log -1 --date=format:'%Y-%m-%d' --format=%cd)
if grep -q '@REVDATE@' "${input_fname}"; then
	sed -i.bak "s/@REVDATE@/${revdate}/" "${input_fname}" || exit 1
	trap 'mv -f "${input_fname}.bak" "${input_fname}"' EXIT
fi

"${mydir}/fix_latexmath" || exit 3

if [[ "${create_tex_output}" == "no" ]]; then
	asciidoctor -r "${extension_path}" -b docbook5 -d book "${input_fname}" || exit 1
	#dblatex --texstyle="${texstyle}" -V -P "table.default.position=[hp]" -t pdf "${xml_fname}" || exit 2
	run_dblatex dblatex -V -P "table.default.position=[hp]" -t pdf "${xml_fname}" || exit 2
else
	asciidoctor -r "${extension_path}" -v -b docbook5 -d book "${input_fname}" || exit 1
	run_dblatex dblatex --texstyle="${texstyle}" -V -P "table.default.position=[H]" -t tex "${xml_fname}" || exit 2
	run_pdflatex pdflatex "${tex_fname}" || exit 3
	run_pdflatex pdflatex "${tex_fname}" || exit 4
fi
